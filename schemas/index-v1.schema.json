{
  "$defs": {
    "MarketIndexEntry": {
      "description": "Compact entry in the market index.",
      "properties": {
        "account_country": {
          "title": "Account Country",
          "type": "string"
        },
        "calculator_coverage_status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Calculator Coverage Status"
        },
        "content_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "data_path": {
          "title": "Data Path",
          "type": "string"
        },
        "derivation_status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Status"
        },
        "locale": {
          "title": "Locale",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "source_updated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Updated At"
        },
        "source_urls": {
          "items": {
            "type": "string"
          },
          "title": "Source Urls",
          "type": "array"
        },
        "stripe_market_code": {
          "title": "Stripe Market Code",
          "type": "string"
        }
      },
      "required": [
        "account_country",
        "stripe_market_code",
        "locale",
        "data_path"
      ],
      "title": "MarketIndexEntry",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/stripe-fee-data/schemas/index-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Index of successfully processed markets.",
  "properties": {
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "markets": {
      "items": {
        "$ref": "#/$defs/MarketIndexEntry"
      },
      "title": "Markets",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "title": "MarketIndex",
  "type": "object"
}
