{
  "$defs": {
    "Language": {
      "description": "A supported language for a market.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        }
      },
      "required": [
        "code"
      ],
      "title": "Language",
      "type": "object"
    },
    "Market": {
      "description": "A discovered Stripe market.\n\nStripe uses locale-style identifiers such as ``en-de`` or ``de-de`` for\nlanguage-country combinations. The ISO 3166-1 alpha-2 account country is\nkept separate from the locale identifier.",
      "properties": {
        "account_country": {
          "title": "Account Country",
          "type": "string"
        },
        "country_name": {
          "title": "Country Name",
          "type": "string"
        },
        "default_currency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Currency"
        },
        "languages": {
          "items": {
            "$ref": "#/$defs/Language"
          },
          "title": "Languages",
          "type": "array"
        },
        "locale": {
          "title": "Locale",
          "type": "string"
        },
        "preferred_language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred Language"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        },
        "status": {
          "default": "discovered",
          "title": "Status",
          "type": "string"
        },
        "stripe_market_code": {
          "title": "Stripe Market Code",
          "type": "string"
        },
        "url_prefix": {
          "title": "Url Prefix",
          "type": "string"
        }
      },
      "required": [
        "stripe_market_code",
        "account_country",
        "country_name",
        "locale",
        "url_prefix"
      ],
      "title": "Market",
      "type": "object"
    },
    "UnsupportedMarket": {
      "description": "A market without a discoverable public fee page.",
      "properties": {
        "account_country": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Account Country"
        },
        "country_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Country Name"
        },
        "first_confirmed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "First Confirmed At"
        },
        "last_confirmed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Confirmed At"
        },
        "last_status": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Status"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "status": {
          "default": "unsupported",
          "title": "Status",
          "type": "string"
        },
        "stripe_market_code": {
          "title": "Stripe Market Code",
          "type": "string"
        },
        "temporary": {
          "default": false,
          "title": "Temporary",
          "type": "boolean"
        },
        "tested_urls": {
          "items": {
            "type": "string"
          },
          "title": "Tested Urls",
          "type": "array"
        }
      },
      "required": [
        "stripe_market_code"
      ],
      "title": "UnsupportedMarket",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/stripe-fee-data/schemas/manifest-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Discovered market manifest.",
  "properties": {
    "aliases": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Aliases",
      "type": "object"
    },
    "fee_page_urls": {
      "additionalProperties": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "title": "Fee Page Urls",
      "type": "object"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "markets": {
      "items": {
        "$ref": "#/$defs/Market"
      },
      "title": "Markets",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "transient_failures": {
      "items": {
        "$ref": "#/$defs/UnsupportedMarket"
      },
      "title": "Transient Failures",
      "type": "array"
    },
    "unsupported": {
      "items": {
        "$ref": "#/$defs/UnsupportedMarket"
      },
      "title": "Unsupported",
      "type": "array"
    }
  },
  "title": "MarketManifest",
  "type": "object"
}
