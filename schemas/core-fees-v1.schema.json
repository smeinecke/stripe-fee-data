{
  "$defs": {
    "CoreFeeEntry": {
      "description": "A single market's confidently derived core fees.",
      "properties": {
        "account_country": {
          "title": "Account Country",
          "type": "string"
        },
        "calculator_coverage_status": {
          "default": "unclassified",
          "title": "Calculator Coverage Status",
          "type": "string"
        },
        "coverage_summary": {
          "$ref": "#/$defs/CoverageSummary"
        },
        "derivation_status": {
          "title": "Derivation Status",
          "type": "string"
        },
        "locale": {
          "title": "Locale",
          "type": "string"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/CoreFeeRule"
          },
          "title": "Rules",
          "type": "array"
        },
        "stripe_market_code": {
          "title": "Stripe Market Code",
          "type": "string"
        },
        "unclassified_count": {
          "default": 0,
          "title": "Unclassified Count",
          "type": "integer"
        }
      },
      "required": [
        "account_country",
        "stripe_market_code",
        "locale",
        "derivation_status"
      ],
      "title": "CoreFeeEntry",
      "type": "object"
    },
    "CoreFeeRule": {
      "description": "A compact, calculator-facing fee rule without provenance.",
      "properties": {
        "account_country": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Account Country"
        },
        "behavior": {
          "default": "additive",
          "title": "Behavior",
          "type": "string"
        },
        "channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Channel"
        },
        "classification_status": {
          "default": "unclassified",
          "title": "Classification Status",
          "type": "string"
        },
        "conditions": {
          "items": {
            "$ref": "#/$defs/FeeCondition"
          },
          "title": "Conditions",
          "type": "array"
        },
        "confidence": {
          "default": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "exactness": {
          "default": "exact",
          "title": "Exactness",
          "type": "string"
        },
        "fee_components": {
          "items": {
            "$ref": "#/$defs/FeeComponent"
          },
          "title": "Fee Components",
          "type": "array"
        },
        "fee_evidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/FeeEvidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "payment_method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Payment Method"
        },
        "product_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Product Id"
        },
        "provider": {
          "default": "stripe",
          "title": "Provider",
          "type": "string"
        },
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        },
        "unit": {
          "default": "per_transaction",
          "title": "Unit",
          "type": "string"
        },
        "variant_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variant Id"
        }
      },
      "required": [
        "rule_id"
      ],
      "title": "CoreFeeRule",
      "type": "object"
    },
    "CoverageSummary": {
      "description": "Summary of how source pricing records were classified.",
      "properties": {
        "ambiguous_entries": {
          "default": 0,
          "title": "Ambiguous Entries",
          "type": "integer"
        },
        "blocking_fee_conflicts": {
          "default": 0,
          "title": "Blocking Fee Conflicts",
          "type": "integer"
        },
        "calculable_rules": {
          "default": 0,
          "title": "Calculable Rules",
          "type": "integer"
        },
        "conflicting_rule_identities": {
          "default": 0,
          "title": "Conflicting Rule Identities",
          "type": "integer"
        },
        "custom_pricing": {
          "default": 0,
          "title": "Custom Pricing",
          "type": "integer"
        },
        "dropped_numeric_entries": {
          "default": 0,
          "title": "Dropped Numeric Entries",
          "type": "integer"
        },
        "free": {
          "default": 0,
          "title": "Free",
          "type": "integer"
        },
        "ignored_non_fee": {
          "default": 0,
          "title": "Ignored Non Fee",
          "type": "integer"
        },
        "included": {
          "default": 0,
          "title": "Included",
          "type": "integer"
        },
        "informational": {
          "default": 0,
          "title": "Informational",
          "type": "integer"
        },
        "informational_conflicts": {
          "default": 0,
          "title": "Informational Conflicts",
          "type": "integer"
        },
        "non_calculable_rules": {
          "default": 0,
          "title": "Non Calculable Rules",
          "type": "integer"
        },
        "numeric_fee_candidates": {
          "default": 0,
          "title": "Numeric Fee Candidates",
          "type": "integer"
        },
        "numeric_source_entries": {
          "default": 0,
          "title": "Numeric Source Entries",
          "type": "integer"
        },
        "reference_only": {
          "default": 0,
          "title": "Reference Only",
          "type": "integer"
        },
        "referenced_numeric_entries": {
          "default": 0,
          "title": "Referenced Numeric Entries",
          "type": "integer"
        },
        "source_entries": {
          "default": 0,
          "title": "Source Entries",
          "type": "integer"
        },
        "unclassified_fee_candidates": {
          "default": 0,
          "title": "Unclassified Fee Candidates",
          "type": "integer"
        },
        "unsupported_fee_shapes": {
          "default": 0,
          "title": "Unsupported Fee Shapes",
          "type": "integer"
        }
      },
      "title": "CoverageSummary",
      "type": "object"
    },
    "FeeComponent": {
      "description": "One calculable or descriptive component of a fee formula.",
      "properties": {
        "amount": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Amount"
        },
        "basis_points": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Basis Points"
        },
        "currency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency"
        },
        "minor_amount": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minor Amount"
        },
        "operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator"
        },
        "schedule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schedule Id"
        },
        "source_entry_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Entry Id"
        },
        "source_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Text"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "type"
      ],
      "title": "FeeComponent",
      "type": "object"
    },
    "FeeCondition": {
      "description": "A single applicability condition for a fee rule.",
      "properties": {
        "dimension": {
          "title": "Dimension",
          "type": "string"
        },
        "evidence": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence"
        },
        "operator": {
          "default": "eq",
          "title": "Operator",
          "type": "string"
        },
        "value": {
          "title": "Value"
        }
      },
      "required": [
        "dimension",
        "value"
      ],
      "title": "FeeCondition",
      "type": "object"
    },
    "FeeEvidence": {
      "description": "Positive or negative evidence supporting a fee classification decision.",
      "properties": {
        "confidence": {
          "default": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "phrases": {
          "items": {
            "type": "string"
          },
          "title": "Phrases",
          "type": "array"
        },
        "source_entry_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Entry Ids",
          "type": "array"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "FeeEvidence",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/stripe-fee-data/schemas/core-fees-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Consolidated core fees across all markets.",
  "properties": {
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "markets": {
      "items": {
        "$ref": "#/$defs/CoreFeeEntry"
      },
      "title": "Markets",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "title": "CoreFees",
  "type": "object"
}
