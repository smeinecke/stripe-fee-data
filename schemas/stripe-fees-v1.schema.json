  "$id": "https://github.com/smeinecke/stripe-fee-data/schemas/stripe-fees-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Per-market normalized output.",
  "properties": {
    "derivation_status": {
      "default": "unclassified",
      "title": "Derivation Status",
      "type": "string"
    },
    "derived_rules": {
      "items": {
        "$ref": "#/$defs/FeeRule"
      },
      "title": "Derived Rules",
      "type": "array"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/PricingEntry"
      },
      "title": "Entries",
      "type": "array"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "market": {
      "$ref": "#/$defs/Market"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/Section"
      },
      "title": "Sections",
      "type": "array"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/Source"
      },
      "title": "Sources",
      "type": "array"
    },
    "transient_failure": {
      "default": false,
      "title": "Transient Failure",
      "type": "boolean"
    },
    "unclassified_entries": {
      "items": {
        "$ref": "#/$defs/PricingEntry"
      },
      "title": "Unclassified Entries",
      "type": "array"
    },
    "unsupported_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
