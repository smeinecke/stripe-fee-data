{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smeinecke/stripe-fee-data/schemas/stripe-fees-v1.schema.json",
  "title": "Stripe market fee output",
  "description": "Normalized and derived fee data for a single Stripe account market.",
  "type": "object",
  "required": ["schema_version", "market", "sources", "entries", "derived_rules", "unclassified_entries", "warnings", "derivation_status"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": ["string", "null"] },
    "market": {
      "type": "object",
      "required": ["stripe_market_code", "account_country", "country_name", "locale", "url_prefix"],
      "properties": {
        "stripe_market_code": { "type": "string" },
        "account_country": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "country_name": { "type": "string" },
        "region": { "type": ["string", "null"] },
        "locale": { "type": "string" },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code"],
            "properties": {
              "code": { "type": "string" },
              "name": { "type": ["string", "null"] }
            }
          }
        },
        "url_prefix": { "type": "string", "format": "uri" },
        "preferred_language": { "type": ["string", "null"] },
        "default_currency": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["discovered", "supported", "unsupported", "pricing_page_unavailable", "transient_failure"] }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requested_url"],
        "properties": {
          "requested_url": { "type": "string", "format": "uri" },
          "canonical_url": { "type": ["string", "null"] },
          "page_id": { "type": ["string", "null"] },
          "page_title": { "type": ["string", "null"] },
          "page_updated_at": { "type": ["string", "null"] },
          "source_updated_at": { "type": ["string", "null"] },
          "etag": { "type": ["string", "null"] },
          "last_modified": { "type": ["string", "null"] },
          "content_sha256": { "type": ["string", "null"] },
          "evidence_text": { "type": ["string", "null"] }
        }
      }
    },
    "sections": { "type": "array", "items": { "type": "object" } },
    "entries": { "type": "array", "items": { "type": "object" } },
    "derived_rules": { "type": "array", "items": { "$ref": "#/definitions/feeRule" } },
    "unclassified_entries": { "type": "array", "items": { "type": "object" } },
    "warnings": { "type": "array", "items": { "type": "object" } },
    "derivation_status": { "type": "string", "enum": ["complete", "partial", "unclassified", "failed"] },
    "transient_failure": { "type": "boolean" },
    "unsupported_reason": { "type": ["string", "null"] }
  },
  "definitions": {
    "feeRule": {
      "type": "object",
      "required": ["rule_id", "provider", "unit", "exactness", "behavior", "classification_status", "confidence"],
      "properties": {
        "rule_id": { "type": "string" },
        "entry_id": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "provider": { "type": "string", "const": "stripe" },
        "account_country": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
        "channel": { "type": ["string", "null"] },
        "payment_method": { "type": ["string", "null"] },
        "card_origin": { "type": ["string", "null"] },
        "card_region": { "type": ["string", "null"] },
        "card_tier": { "type": ["string", "null"] },
        "customer_country": { "type": ["string", "null"] },
        "presentment_currency": { "type": ["string", "null"] },
        "settlement_currency": { "type": ["string", "null"] },
        "currency_conversion_required": { "type": ["boolean", "null"] },
        "transaction_amount_min": { "type": ["string", "null"] },
        "transaction_amount_max": { "type": ["string", "null"] },
        "billing_type": { "type": ["string", "null"] },
        "recurring": { "type": ["boolean", "null"] },
        "payout_type": { "type": ["string", "null"] },
        "dispute_state": { "type": ["string", "null"] },
        "percentage": { "type": ["string", "null"] },
        "basis_points": { "type": ["string", "null"] },
        "fixed_amount": { "type": ["string", "null"] },
        "fixed_amount_minor": { "type": ["string", "null"] },
        "fixed_currency": { "type": ["string", "null"] },
        "minimum_amount": { "type": ["string", "null"] },
        "maximum_amount": { "type": ["string", "null"] },
        "unit": { "type": "string", "enum": ["per_transaction", "per_attempt", "per_dispute", "per_payout", "monthly", "yearly", "per_invoice", "per_charge", "informational"] },
        "exactness": { "type": "string", "enum": ["exact", "from", "range", "tiered", "included", "free", "custom", "non_calculable"] },
        "behavior": { "type": "string", "enum": ["additive", "alternative", "mutually_exclusive", "conditional", "informational"] },
        "conditions": { "type": "array", "items": { "type": "object" } },
        "additional_fees": { "type": "array", "items": { "type": "string" } },
        "source_text": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] },
        "classification_status": { "type": "string", "enum": ["classified", "unclassified", "non_calculable", "partial"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "classification_evidence": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
